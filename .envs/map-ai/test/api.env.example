# 内网测试环境 - 后端 API 配置模板
# 用途：内网测试环境部署

# 环境标识
NODE_ENV=production
DEPLOY_ENV=test

# 数据库 - 内网 PostgreSQL
DATABASE_URL=postgresql://user:password@db-host:5432/txwx_db?options=-c%20TimeZone%3DAsia%2FShanghai

# Redis - 内网 Redis
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_URL=redis://redis-host:6379
REDIS_PASSWORD=your_redis_password

# Agent - 内网容器
AGENT_BASE_URL=http://agent:8001
AGENT_TIMEOUT_MS=20000

# API 服务
PORT=3000
STREAM_CHUNK_SIZE=6

# OpenAI 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE_URL=https://api.deepseek.com/v1
MODEL=gpt-4o-mini
