# 本地开发环境 - 前端 Web 配置模板
# 用途：本地开发调试，Vite 注入环境变量 (VITE_* 前缀)

# 环境标识
VITE_DEPLOY_ENV=local
VITE_NODE_ENV=development

# 天地图 Token - 用于加载天地图服务
# 申请地址：https://lbs.tianditu.gov.cn/
VITE_TIANDITU_TOKEN=your_tianditu_token_here

# Cesium Ion Token - 用于加载 Cesium Ion 资源
# 申请地址：https://cesium.com/ion/
VITE_CESIUM_ION=your_cesium_ion_token_here

# API 代理配置
VITE_API_BASE_URL=http://localhost:3000
