# 本地开发环境 - 后端 API 配置模板
# 用途：本地开发调试，连接本地 Docker 容器中的 DB/Redis

# 环境标识
NODE_ENV=development
DEPLOY_ENV=local

# 数据库 - 本地 Docker 容器 (端口 5433)
DATABASE_URL=postgresql://txwx:txms9999@localhost:5433/txwx_db

# Redis - 本地 Docker 容器 (端口 6380)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380
REDIS_PASSWORD=

# Agent - 本地运行
AGENT_BASE_URL=http://localhost:8001
AGENT_TIMEOUT_MS=20000

# API 服务
PORT=3000
STREAM_CHUNK_SIZE=6

# OpenAI 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE_URL=
MODEL=gpt-4o-mini
